# Copy this to `examples/.env` (same directory as the .ulx files — `ulx run`
# loads a `.env` next to whichever file you're running) and fill in the keys
# for whichever vendors you actually enabled in `examples/ulexite.toml`
# (see `examples/ulexite.example.toml`). `.env` is gitignored; never commit
# real keys. Variables already set in your shell always take precedence
# over this file — it only fills in what isn't already exported.

OPENAI_API_KEY=
AZURE_OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
COHERE_API_KEY=
