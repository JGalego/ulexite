// examples/pdf_qa.ulx
// See docs/spec/21-examples.md §21.3
//
// Same vendor split as summarize.ulx: `vision` (the OCR fallback) on
// Anthropic, `chat` on Groq. Self-contained, no ulexite.toml needed —
// export ANTHROPIC_API_KEY/GROQ_API_KEY to run it for real.
//
// `pdf.extract_text` is real (pure-Rust text extraction — see
// crates/ulx-runtime/src/stdlib.rs) and finds `fixtures/sample.pdf`'s
// actual text layer, so the `vision` OCR branch never fires for this
// fixture — that's correct behavior, not a limitation, for a PDF that
// already has a text layer. `pdf.to_images` genuinely isn't implemented
// (rasterizing a PDF page needs a real rendering engine, none of which are
// pure Rust) — deliberately called only inside the `else` branch, not
// unconditionally in a `with` block, so a text-layer PDF like this one
// never touches it at all. Point `doc` at a scanned, no-text-layer PDF to
// see that branch's honest `NotImplemented` error instead of a silent fake
// OCR result.

import "pdf" as pdf
import "vision" as vision

provider Anthropic {
  vendor: "anthropic"
  api_key_env: "ANTHROPIC_API_KEY"
  vision: "claude-haiku-4-5-20251001"
}

provider Groq {
  vendor: "groq"
  api_key_env: "GROQ_API_KEY"
  chat: "llama-3.3-70b-versatile"
}

conversation PdfQA(doc: pdf, question: text) -> text {
  text_layer = pdf.extract_text(doc)
  ocr_text = if text_layer.length > 0 {
    text_layer
  } else {
    page_images = pdf.to_images(doc)
    ask vision(page_images, provider: "Anthropic") { user: """Transcribe all text in these pages.""" }
  }
  ask chat(provider: "Groq") {
    system: """Answer strictly using the provided document text."""
    user: """Document:\n{ocr_text}\n\nQuestion: {question}"""
  } -> answer: text
  answer
}
