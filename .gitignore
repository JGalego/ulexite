/target
**/*.rs.bk
.DS_Store
*.vsix
node_modules/
tooling/vscode-ulx/out/

# local ulx runtime state (cache/artifacts/traces/run manifests, §11.2/§12.5/§18) — never checked in
.ulexite/

# provider API keys (README's "Configuring providers") — real secrets belong
# here, never in ulexite.toml; see .env.example / examples/.env.example
.env

# a personal copy of ulexite.example.toml (README's "Configuring providers")
# with whichever real vendors you've enabled locally — never the shipped
# template itself, so this stays local like .env
examples/ulexite.toml

# website/ (Docusaurus) build outputs — regenerated by `just docs-build`/
# `just docs-serve` and by .github/workflows/pages-deploy.yml, never
# checked in. website/static/wasm/ specifically is wasm-pack's output for
# crates/ulx-wasm (the Playground's compiler backend), not hand-written
# site content, even though it lives under static/.
website/build/
website/.docusaurus/
website/static/wasm/
